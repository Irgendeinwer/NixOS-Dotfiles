{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "nix"
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "matchDepNames": ["nixpkgs-unstable"],
      "matchUpdateTypes": ["digest"],
      "enabled": true,
      "automerge": true
    },
    {
      "matchManagers": ["nix"],
      "excludeDepNames": ["nixpkgs-unstable"],
      "enabled": false
    }
  ]
}
