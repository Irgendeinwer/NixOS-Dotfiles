{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "ignoreDeps": [
    "wallpaper"
  ],
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "groupName": "all nix flake updates",
      "groupSlug": "nix-flake-updates",
      "matchPackageNames": ["*"],
      "automerge": true
    }
  ]
}
